{
  "name": "@tkodev/config-eslint-next",
  "version": "0.2.0",
  "description": "Shared ESLint flat config for Next.js projects at tkodev.",
  "type": "module",
  "main": "./eslint.config.mjs",
  "exports": {
    ".": {
      "types": "./eslint.config.d.mts",
      "default": "./eslint.config.mjs"
    }
  },
  "files": [
    "eslint.config.mjs",
    "eslint.config.d.mts",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "eslintconfig",
    "nextjs",
    "typescript"
  ],
  "license": "MIT",
  "author": "tkodev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkodev/config-eslint-next.git"
  },
  "homepage": "https://github.com/tkodev/config-eslint-next#readme",
  "bugs": {
    "url": "https://github.com/tkodev/config-eslint-next/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@next/eslint-plugin-next": "^16.0.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "next": ">=16",
    "typescript": ">=5"
  },
  "devDependencies": {
    "eslint": "^9.39.4"
  }
